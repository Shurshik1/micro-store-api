# 1. Указываем "фундамент". Берем готовую операционную систему Linux с уже установленным Node.js 20-й версии. 
# Приставка alpine означает, что это супер-легкая версия (весит мегабайт 40 вместо гигабайта).
FROM node:20-alpine

# 2. Говорим Докеру: "Создай внутри себя папку /app и все дальнейшие команды выполняй внутри нее".
WORKDIR /app

# 3. Копируем файлы package.json (и package-lock.json, если есть) из твоей папки на компьютере внутрь контейнера в папку /app.
COPY package*.json ./

# 4. Запускаем установку всех библиотек. (Благодаря кэшу, Докер будет делать это только если package.json изменится!)
RUN npm install

# 5. Копируем ВЕСЬ остальной код нашего проекта (папки src, prisma и т.д.) внутрь контейнера.
COPY . .

# 6. Супер-важный шаг для Prisma! Генерируем клиент базы данных специально под Linux внутри контейнера.
RUN npx prisma generate

# 7. Просто документируем, что наш сервер внутри контейнера будет работать на 3001 порту.
EXPOSE 3001

# 8. Финальный аккорд. Какую команду выполнить, когда контейнер "оживет"?
CMD ["sh", "-c", "npx prisma db push && npm run dev"]